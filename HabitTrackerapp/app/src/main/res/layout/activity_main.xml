<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Habit Tracker"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1B4332" />

        <TextView
            android:id="@+id/motivationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Small habits create big changes."
            android:textSize="17sp"
            android:textColor="#52796F"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="22dp" />

        <TextView
            android:id="@+id/dashboardText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No habit added yet."
            android:textSize="19sp"
            android:textColor="#1B4332"
            android:textStyle="bold"
            android:background="#D8F3DC"
            android:padding="20dp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/streakText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Streak: 0 days"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#2D6A4F"
            android:padding="18dp"
            android:layout_marginBottom="25dp" />

        <Button
            android:id="@+id/addHabitBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add / Edit Habit" />

        <Button
            android:id="@+id/settingsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:layout_marginTop="14dp" />

        <Button
            android:id="@+id/infoBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Instructions"
            android:layout_marginTop="14dp" />

    </LinearLayout>
</ScrollView>